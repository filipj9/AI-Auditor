{
  "manifest_version": 3,
  "name": "AI Auditor Assistant",
  "version": "1.0",
  "description": "Automates filling of GWD forms using AI-extracted data",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}